<Window x:Class="DataSenderPlusProject.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation"
        Height="230"
        Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="License Not Found. Please send the Hardware ID to support."
            FontWeight="Bold"
            TextWrapping="Wrap"/>

        <TextBox
            x:Name="txtHardware"
            Grid.Row="2"
            Height="70"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"/>

        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

            <Button
                x:Name="btnCopy"
                Width="100"
                Margin="0,0,10,0"
                Content="Copy"
                Click="btnCopy_Click"/>

            <Button
                Width="100"
                Content="Exit"
                Click="btnExit_Click"/>

        </StackPanel>

    </Grid>

</Window>